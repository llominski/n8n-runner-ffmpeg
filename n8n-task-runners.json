{
  "task-runners": [
    {
      "runner-type": "javascript",
      "workdir": "/home/runner",
      "command": "/usr/local/bin/node",
      "args": [
        "--disallow-code-generation-from-strings",
        "--disable-proto=delete",
        "/opt/runners/task-runner-javascript/dist/start.js"
      ],
      "health-check-server-port": "5681",
      "allowed-env": [
        "PATH",
        "GENERIC_TIMEZONE",
        "NODE_OPTIONS",
        "N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_SENTRY_DSN",
        "N8N_VERSION",
        "ENVIRONMENT",
        "DEPLOYMENT_NAME",
        "HOME"
      ],
      "env-overrides": {
        "NODE_FUNCTION_ALLOW_BUILTIN": "crypto,path,fs,os",
        "NODE_FUNCTION_ALLOW_EXTERNAL": "moment,uuid",
        "N8N_RUNNERS_HEALTH_CHECK_SERVER_HOST": "0.0.0.0"
      }
    },
    {
      "runner-type": "python",
      "workdir": "/home/runner",
      "command": "/opt/runners/task-runner-python/.venv/bin/python",
      "args": ["-I", "-B", "-X", "disable_remote_debug", "-m", "src.main"],
      "health-check-server-port": "5682",
      "allowed-env": [
        "PATH",
        "N8N_RUNNERS_LAUNCHER_LOG_LEVEL",
        "N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_SENTRY_DSN",
        "N8N_VERSION",
        "ENVIRONMENT",
        "DEPLOYMENT_NAME"
      ],
      "env-overrides": {
        "N8N_RUNNERS_STDLIB_ALLOW": "json,os,pathlib,shutil,subprocess,tempfile,base64,sys,re,math,random,time,datetime,collections,itertools,functools,io,string,struct,hashlib,hmac,secrets,uuid,urllib,http,email,html,xml,csv,sqlite3,gzip,zipfile,tarfile,threading,multiprocessing,asyncio,socket,logging,warnings,traceback,inspect,copy,typing,enum,dataclasses,contextlib,abc,weakref,gc,platform,signal,stat,glob,fnmatch,pickle,shelve,queue,heapq,bisect,array,decimal,fractions,statistics,textwrap,unicodedata,codecs,binascii",
        "N8N_RUNNERS_EXTERNAL_ALLOW": "numpy,pandas,moviepy,av,imageio_ffmpeg",
        "N8N_RUNNERS_BUILTINS_ALLOW": "open,print,len,range,enumerate,zip,str,int,float,bool,list,dict,tuple,set,frozenset,bytes,bytearray,type,hasattr,getattr,setattr,callable,isinstance,issubclass,abs,all,any,ascii,bin,chr,compile,complex,delattr,divmod,eval,exec,format,getattr,globals,hasattr,hash,hex,id,input,isinstance,issubclass,iter,len,locals,max,min,next,oct,ord,pow,repr,reversed,round,setattr,slice,sorted,staticmethod,sum,super,vars"
      }
    }
  ]
}